{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "Kodeck",
  "version": "0.0.1",
  "identifier": "com.kodeck.app",
  "build": {
    "beforeDevCommand": "npx concurrently -n server,client -c blue,green \"pnpm --filter @kodeck/server dev\" \"pnpm --filter client dev\"",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter client build",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Kodeck",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/kodeck-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
