{
  "name": "kodeck",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "dev": "concurrently -n server,client -c blue,green \"vp run server#dev\" \"vp run client#dev\""
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.7"
  },
  "devDependencies": {
    "concurrently": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  }
}
